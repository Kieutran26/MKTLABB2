# Copy this file to .env.local and fill in values (Vite reads .env.local automatically).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for AI features (Brand Vault, IMC, Problem→Question, etc.)
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=YOUR_GOOGLE_AI_STUDIO_API_KEY

# Optional
# VITE_BACKEND_URL=http://localhost:3001

# --- Firebase Authentication (Google Login) ---
# Get these from: Firebase Console → Project Settings → Your apps → Web app
# Enable "Google" sign-in provider in: Firebase Console → Authentication → Sign-in method
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
