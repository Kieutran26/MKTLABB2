# Copy this file to .env.local and fill in values (Vite reads .env.local automatically).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for AI features (Brand Vault, IMC, Problem→Question, etc.)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# If REST calls 404 on model name, set an id from List Models (ai.google.dev/api/rest/v1beta/models.list)
# Optional: override the default model used by the local AI proxy
# OPENAI_MODEL=gpt-4.1

# Optional
# VITE_BACKEND_URL=http://localhost:3011

# --- Firebase Authentication (Google Login) ---
# Get these from: Firebase Console → Project Settings → Your apps → Web app
# Enable "Google" sign-in provider in: Firebase Console → Authentication → Sign-in method
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
